  _choices:
  - ChoiceText: "\uAE30\uC6D0\uD55C\uB2E4"
    ChoiceDescription: "\uC2E0\uC804\uC5D0 \uAE30\uB3C4\uB97C \uC62C\uB9BD\uB2C8\uB2E4."
    Outcome:
      ResultText: "\uB530\uB73B\uD55C \uBE5B\uC774 \uD30C\uD2F0\uB97C \uAC10\uC309\uB2C8\uB2E4.
