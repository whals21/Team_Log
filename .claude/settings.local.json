  },
  "permissions": {
    "allow": [
      "mcp__mcp-unity__get_scene_info",
      "mcp__zai-mcp-server__analyze_image",
      "mcp__mcp-unity__create_scene",
      "mcp__mcp-unity__batch_execute",
      "mcp__mcp-unity__recompile_scripts",
